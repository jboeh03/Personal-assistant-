# .env.example — environment variables for this project's MCP connectors and tooling.
#
# Copy to .env and fill in real values. NEVER commit .env (it is gitignored).
# NEVER paste these values into chat — set them here or in your Claude Code
# web-environment secret config / hosting provider env vars.
#
#   cp .env.example .env
#   # then edit .env with your real values

# ─── MCP connectors (.mcp.json) ──────────────────────────────────────────────

# GitHub MCP — personal access token (repo scope as needed)
# https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=

# Supabase MCP — project ref + personal access token
# Project ref: Supabase dashboard → Project Settings → General → Reference ID
# Access token: https://supabase.com/dashboard/account/tokens
SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=

# Notes:
# - sequential-thinking, memory, context7, parallel-search, playwright need NO key.
# - vercel MCP uses OAuth in your editor (no key here).

# ─── App-level LLM keys (NOT MCP servers — used by app code if/when built) ────

# Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Google Gemini API key (https://aistudio.google.com/apikey)
# Gemini is an LLM API, not an MCP connector — it belongs in app code / env, not .mcp.json
GEMINI_API_KEY=
